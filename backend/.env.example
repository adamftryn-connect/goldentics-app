# SERVER CONFIG
NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000

# DATABASE (PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/goldentics_db

# AUTH (JWT)
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRES_IN=7d

# HUGGING FACE / HF SPACE (prediksi AI)
# URL wajib untuk prediksi nyata; API key opsional untuk Space publik
HUGGING_FACE_API_URL=https://denizzf-goldentics.hf.space/predict
# HUGGING_FACE_API_KEY=
